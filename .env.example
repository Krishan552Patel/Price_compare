# Neon PostgreSQL Database
NEON_DATABASE_URL=postgresql://user:password@your-host.neon.tech/neondb?sslmode=require

# Redis (optional — enables price caching; Upstash URL works too)
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6380

# GitHub (optional - for higher API rate limits)
# Without this you get 60 requests/hour, with it you get 5000/hour
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=
